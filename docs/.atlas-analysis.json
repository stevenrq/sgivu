  "keyFeatures": [
    "OAuth 2.1/OIDC authentication with JWT tokens",
    "Microservices architecture with Spring Cloud",
    "Vehicle inventory management with S3 image storage",
    "Client and purchase-sale tracking",
    "Machine learning demand prediction with FastAPI",
    "BFF pattern for secure token management",
    "Docker Compose orchestration",
    "Redis session storage for horizontal scaling",
    "Distributed tracing with Zipkin"
  ],
  "publicApiSurface": [
    "POST /oauth2/authorize - OAuth2 authorization",
    "POST /oauth2/token - Token endpoint",
    "GET /auth/session - BFF session info",
    "GET /v1/users - List users",
    "POST /v1/users - Create user",
    "GET /v1/vehicles - List vehicles",
    "POST /v1/vehicles - Create vehicle",
    "GET /v1/clients - List clients",
    "POST /v1/clients - Create client",
    "GET /v1/purchase-sales - List transactions",
    "POST /v1/purchase-sales - Create transaction",
    "POST /v1/ml/predict - Demand prediction",
    "POST /v1/ml/retrain - Retrain model",
    "GET /v1/ml/models/latest - Get latest model metadata"
  ]
