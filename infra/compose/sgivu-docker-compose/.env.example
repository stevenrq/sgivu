########## AWS ##########
AWS_ACCESS_KEY=your-aws-access-key-here
AWS_SECRET_KEY=your-aws-secret-key-here
AWS_REGION=us-east-1

########## AWS S3 ##########
AWS_VEHICLES_BUCKET=sgivu-vehicle-images
# Incluir el dominio EC2 (Nginx) y opcionalmente S3 directo
AWS_S3_ALLOWED_ORIGINS=http://your-ec2-public-hostname,http://your-s3-bucket.s3-website-region.amazonaws.com

########## SPRING PROFILE ##########
SPRING_PROFILES_ACTIVE=prod

########## COMUNES ##########
# URL del frontend Angular (a través de Nginx - mismo dominio que backend)
# IMPORTANTE: Usar el mismo hostname de EC2 para evitar problemas de cookies cross-origin
PROD_ANGULAR_APP_URL=http://your-ec2-public-hostname
SERVICE_INTERNAL_SECRET_KEY=your-internal-secret-key-here

########## URL DE LOS SERVICIOS ##########
EUREKA_URL=http://sgivu-discovery:8761/eureka
# URL del Auth Server - DEBE coincidir con ISSUER_URL para evitar mismatch de issuer
# Los contenedores resuelven este hostname via extra_hosts en docker-compose.yml
SGIVU_AUTH_URL=http://your-ec2-public-hostname
SGIVU_USER_URL=http://sgivu-user:8081
SGIVU_CLIENT_URL=http://sgivu-client:8082
SGIVU_VEHICLE_URL=http://sgivu-vehicle:8083
SGIVU_PURCHASE_SALE_URL=http://sgivu-purchase-sale:8084
# URL pública del Gateway (a través de Nginx, puerto 80 - SIN puerto)
SGIVU_GATEWAY_URL=http://your-ec2-public-hostname

# ISSUER_URL: URL pública del Auth Server (debe coincidir con SGIVU_AUTH_URL)
ISSUER_URL=http://your-ec2-public-hostname

########## JWT ##########
JWT_KEYSTORE_LOCATION=classpath:keystore.jks
JWT_KEYSTORE_PASSWORD=your-keystore-password-here
JWT_KEY_ALIAS=sgivu-jwt
JWT_KEY_PASSWORD=your-key-password-here

SGIVU_GATEWAY_SECRET=your-gateway-secret-here

########## REDIS ##########
REDIS_HOST=sgivu-redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

########## MYSQL ##########
MYSQL_HOST=sgivu-mysql
MYSQL_ROOT_PASSWORD=your-mysql-root-password-here
MYSQL_DATABASE=sgivu_zipkin_db
MYSQL_PASSWORD=your-mysql-password-here
MYSQL_USER=zipkin

########## ZIPKIN ##########
STORAGE_TYPE=mysql
# MYSQL_HOST=sgivu-mysql -> duplicado
MYSQL_DB=sgivu_zipkin_db
# MYSQL_USER=zipkin -> duplicado
MYSQL_PASS=your-mysql-password-here

########## POSTGRES ##########
POSTGRES_HOST=sgivu-postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password-here

########## AUTH DB ##########
PROD_AUTH_DB_HOST=sgivu-postgres
PROD_AUTH_DB_PORT=5432
PROD_AUTH_DB_NAME=sgivu_auth_db
PROD_AUTH_DB_USERNAME=postgres
PROD_AUTH_DB_PASSWORD=your-postgres-password-here

########## USER DB ##########
PROD_USER_DB_HOST=sgivu-postgres
PROD_USER_DB_PORT=5432
PROD_USER_DB_NAME=sgivu_user_db
PROD_USER_DB_USERNAME=postgres
PROD_USER_DB_PASSWORD=your-postgres-password-here

########## CLIENT DB ##########
PROD_CLIENT_DB_HOST=sgivu-postgres
PROD_CLIENT_DB_PORT=5432
PROD_CLIENT_DB_NAME=sgivu_client_db
PROD_CLIENT_DB_USERNAME=postgres
PROD_CLIENT_DB_PASSWORD=your-postgres-password-here

########## VEHICLE DB ##########
PROD_VEHICLE_DB_HOST=sgivu-postgres
PROD_VEHICLE_DB_PORT=5432
PROD_VEHICLE_DB_NAME=sgivu_vehicle_db
PROD_VEHICLE_DB_USERNAME=postgres
PROD_VEHICLE_DB_PASSWORD=your-postgres-password-here

########## PURCHASE SALE DB ##########
PROD_PURCHASE_SALE_DB_HOST=sgivu-postgres
PROD_PURCHASE_SALE_DB_PORT=5432
PROD_PURCHASE_SALE_DB_NAME=sgivu_purchase_sale_db
PROD_PURCHASE_SALE_DB_USERNAME=postgres
PROD_PURCHASE_SALE_DB_PASSWORD=your-postgres-password-here

########## FLYWAY ##########
FLYWAY_BASELINE_ON_MIGRATE=false

###################################################### sgivu-ml (FastAPI) #######################################################
ENVIRONMENT=prod
APP_NAME=sgivu-ml
APP_VERSION=0.1.0

# Descubrimiento OIDC: extrae issuer y JWKS automáticamente.
SGIVU_AUTH_DISCOVERY_URL=http://sgivu-auth:9000/.well-known/openid-configuration

# Modelos y pipeline
MODEL_DIR=models
MODEL_NAME=demand_forecaster
REQUEST_TIMEOUT_SECONDS=15
DEFAULT_HORIZON_MONTHS=6
MIN_HISTORY_MONTHS=1
TARGET_COLUMN=sales_count

# Programación de reentrenamiento (si se usa cron)
RETRAIN_CRON="0 3 1 * *"
RETRAIN_TIMEZONE=UTC

# Permisos requeridos para para cada endpoint de sgivu-ml.
# Si quieres deshabilitar chequeo granular, deja vacío el valor correspondiente.
PERMISSIONS_PREDICT=ml:predict
PERMISSIONS_RETRAIN=ml:retrain
PERMISSIONS_MODELS=ml:models

# Seleccion de DB: DATABASE_URL o PROD_ML_DB_* / PROD_ML_DB_*
DATABASE_ENV=prod
PROD_ML_DB_HOST=sgivu-postgres
PROD_ML_DB_PORT=5432
PROD_ML_DB_NAME=sgivu_ml_db
PROD_ML_DB_USERNAME=postgres
PROD_ML_DB_PASSWORD=your-postgres-password-here
DATABASE_AUTO_CREATE=false
DATABASE_ECHO=false