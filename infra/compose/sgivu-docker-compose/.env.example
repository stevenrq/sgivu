########## AWS ##########
AWS_ACCESS_KEY=your-aws-access-key-here
AWS_SECRET_KEY=your-aws-secret-key-here
AWS_REGION=us-east-1

########## AWS S3 ##########
AWS_VEHICLES_BUCKET=your-sgivu-vehicle-images-bucket
AWS_S3_ALLOWED_ORIGINS=https://your-frontend-domain.com

########## SPRING PROFILE ##########
SPRING_PROFILES_ACTIVE=prod

########## COMUNES ##########
PROD_ANGULAR_APP_URL=https://your-frontend-domain.com
SERVICE_INTERNAL_SECRET_KEY=your-internal-service-secret-key

########## URL DE LOS SERVICIOS ##########
EUREKA_URL=http://sgivu-discovery:8761/eureka
SGIVU_AUTH_URL=http://sgivu-auth:9000
SGIVU_USER_URL=http://sgivu-user:8081
SGIVU_CLIENT_URL=http://sgivu-client:8082
SGIVU_VEHICLE_URL=http://sgivu-vehicle:8083
SGIVU_PURCHASE_SALE_URL=http://sgivu-purchase-sale:8084

########## JWT ##########
JWT_KEYSTORE_LOCATION=classpath:keystore.jks
JWT_KEYSTORE_PASSWORD=your-keystore-password
JWT_KEY_ALIAS=sgivu-jwt
JWT_KEY_PASSWORD=your-key-password

########## ZIPKIN ##########
STORAGE_TYPE=mysql
MYSQL_HOST=your-mysql-rds-endpoint.rds.amazonaws.com
MYSQL_DB=sgivu_zipkin_db
MYSQL_USER=zipkin
MYSQL_PASS=your-mysql-password

########## AUTH DB ##########
PROD_AUTH_DB_HOST=your-postgres-rds-endpoint.rds.amazonaws.com
PROD_AUTH_DB_PORT=5432
PROD_AUTH_DB_NAME=sgivu_auth_db
PROD_AUTH_DB_USERNAME=postgres
PROD_AUTH_DB_PASSWORD=your-postgres-password

########## USER DB ##########
PROD_USER_DB_HOST=your-postgres-rds-endpoint.rds.amazonaws.com
PROD_USER_DB_PORT=5432
PROD_USER_DB_NAME=sgivu_user_db
PROD_USER_DB_USERNAME=postgres
PROD_USER_DB_PASSWORD=your-postgres-password

########## CLIENT DB ##########
PROD_CLIENT_DB_HOST=your-postgres-rds-endpoint.rds.amazonaws.com
PROD_CLIENT_DB_PORT=5432
PROD_CLIENT_DB_NAME=sgivu_client_db
PROD_CLIENT_DB_USERNAME=postgres
PROD_CLIENT_DB_PASSWORD=your-postgres-password

########## VEHICLE DB ##########
PROD_VEHICLE_DB_HOST=your-postgres-rds-endpoint.rds.amazonaws.com
PROD_VEHICLE_DB_PORT=5432
PROD_VEHICLE_DB_NAME=sgivu_vehicle_db
PROD_VEHICLE_DB_USERNAME=postgres
PROD_VEHICLE_DB_PASSWORD=your-postgres-password

########## PURCHASE SALE DB ##########
PROD_PURCHASE_SALE_DB_HOST=your-postgres-rds-endpoint.rds.amazonaws.com
PROD_PURCHASE_SALE_DB_PORT=5432
PROD_PURCHASE_SALE_DB_NAME=sgivu_purchase_sale_db
PROD_PURCHASE_SALE_DB_USERNAME=postgres
PROD_PURCHASE_SALE_DB_PASSWORD=your-postgres-password

###################################################### sgivu-ml (FastAPI) #######################################################
ENVIRONMENT=prod
APP_NAME=sgivu-ml
APP_VERSION=0.1.0

# Descubrimiento OIDC: extrae issuer y JWKS automáticamente.
SGIVU_AUTH_DISCOVERY_URL=http://sgivu-auth:9000/.well-known/openid-configuration

# Modelos y pipeline
MODEL_DIR=models
MODEL_NAME=demand_forecaster
REQUEST_TIMEOUT_SECONDS=15
DEFAULT_HORIZON_MONTHS=6
MIN_HISTORY_MONTHS=1
TARGET_COLUMN=sales_count

# Programación de reentrenamiento (si se usa cron)
RETRAIN_CRON="0 3 1 * *"
RETRAIN_TIMEZONE=UTC

# Permisos requeridos para para cada endpoint de sgivu-ml.
# Si quieres deshabilitar chequeo granular, deja vacío el valor correspondiente.
PERMISSIONS_PREDICT=ml:predict
PERMISSIONS_RETRAIN=ml:retrain
PERMISSIONS_MODELS=ml:models

# Seleccion de DB: DATABASE_URL o DEV_ML_DB_* / PROD_ML_DB_*
DATABASE_ENV=prod
PROD_ML_DB_HOST=sgivu-postgres
PROD_ML_DB_PORT=5432
PROD_ML_DB_NAME=sgivu_ml
PROD_ML_DB_USERNAME=postgres
PROD_ML_DB_PASSWORD=changeme
DATABASE_AUTO_CREATE=false
DATABASE_ECHO=false
